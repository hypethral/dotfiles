{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar at the bottom of your screen
    "height": 28, // Waybar height
    // "width": 1366, // Waybar width
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces","hyprland/window"],
    "modules-right": ["backlight", "pulseaudio", "custom/cpu", "network", "custom/gpuState", "battery", "custom/clock", "tray"],
    "hyprland/workspaces": {
        // "disable-scroll": true,
        // "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "1": "I",
            "2": "II",
            "3": "III",
            "4": "IV",
            "5": "V",
            "6": "VI",
            "7": "VII",
            "8": "IIX",
            "9": "IX",
	    "10": "X"
        }
    },
    "hyprland/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
   "custom/clock": {
	"format": "{}",
	"interval": 60,
  	"exec": "~/.scripts/datey",       
    },
    "custom/gpuState": {
        "format": "{}",
	"interval": 2,
        "exec": "~/.scripts/gpuState"
    },
    "custom/cpu": {
        "format": "{}",
	"interval": 1,
	"exec": "~/.scripts/temperature"
    },
    "battery": {
        "bat": "BAT0",
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },
    "network": {
	"interface": "wlp0s20f3",
	"format-wifi": " {bandwidthUpBytes} {bandwidthDownBytes}",        
	"format-disconnected": "Disconnected ⚠",
	"interval": 1
    },
    "pulseaudio": {
        "format": " {volume}%",
        "format-muted": "muted",
        "scroll-step": 1,
        "on-click-right": "pavucontrol",
	"on-click": "amixer set Master toggle"
   },
  "backlight": {
  	"device": "intel_backlight",
  	"format": "{icon} {percent}%",
  	"format-icons": [""]
  }

}
